load("@bazel_skylib//:bzl_library.bzl", "bzl_library")

package(default_visibility = ["//visibility:public"])

exports_files(glob(["*.bzl"]))

bzl_library(
    name = "terraform",
    srcs = ["terraform.bzl"],
)

bzl_library(
    name = "actions",
    srcs = ["actions.bzl"],
)

bzl_library(
    name = "tfdoc",
    srcs = ["tfdoc.bzl"],
)

bzl_library(
    name = "tflint",
    srcs = ["tflint.bzl"],
)