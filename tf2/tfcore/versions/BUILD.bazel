# Terraform versions management
load("@bazel_skylib//:bzl_library.bzl", "bzl_library")

package(default_visibility = ["//tf2:__subpackages__"])

bzl_library(
    name = "versions",
    srcs = ["versions.bzl"],
    deps = [
        "//tf2/providers/core:info",
        "//tf2/tools/runners:sh_toolchain",
        "//tf2/tools/runners:shell_utils",
    ],
)

bzl_library(
    name = "lockfile",
    srcs = ["lockfile.bzl"],
)
