"""Module validation rules"""

load("@bazel_skylib//:bzl_library.bzl", "bzl_library")

package(default_visibility = ["//visibility:public"])

exports_files(glob(["*.bzl"]))

bzl_library(
    name = "validate",
    srcs = ["validate.bzl"],
    deps = [
        "//tf2/tools:terraform",
        "//tf2/internal/utils:runfiles",
    ],
)