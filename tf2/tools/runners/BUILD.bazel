"""Tool execution wrappers"""

load("@bazel_skylib//:bzl_library.bzl", "bzl_library")

package(default_visibility = ["//visibility:public"])

exports_files([
    "terraform.bzl",
    "tflint.bzl",
    "tfdoc.bzl",
    "tool_paths.bzl",
])

bzl_library(
    name = "terraform",
    srcs = ["terraform.bzl"],
    deps = [
        ":shell_utils",
        ":tool_paths",
    ],
)

bzl_library(
    name = "tflint",
    srcs = ["tflint.bzl"],
    deps = [
        ":tool_paths",
    ],
)

bzl_library(
    name = "tfdoc",
    srcs = ["tfdoc.bzl"],
    deps = [
        ":tool_paths",
    ],
)

bzl_library(
    name = "tool_paths",
    srcs = ["tool_paths.bzl"],
)

bzl_library(
    name = "shell_utils",
    srcs = ["shell_utils.bzl"],
)