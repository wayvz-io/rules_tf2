use flake

# Export the path to Bazel completion for manual sourcing
BAZEL_PATH=$(which bazel 2>/dev/null)
if [[ -n "$BAZEL_PATH" ]]; then
  BAZEL_STORE_PATH=$(dirname $(dirname "$BAZEL_PATH"))
  export BAZEL_COMPLETION_FILE="${BAZEL_STORE_PATH}/share/zsh/site-functions/_bazel"
  
  # Provide instruction for enabling completion
  if [[ -n "$ZSH_VERSION" ]] && [[ ! -f "$HOME/.zshrc.d/bazel-completion" ]]; then
    echo "ℹ️  To enable Bazel completion, run: source .direnv/bazel-completion.zsh"
  fi
fi