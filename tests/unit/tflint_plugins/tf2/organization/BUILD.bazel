load("//tf2/tflint:test.bzl", "tf_lint_negative_test", "tf_lint_test")

# Test properly organized files (should pass)
tf_lint_test(
    name = "properly_organized_test",
    size = "small",
    srcs = glob(["properly_organized/*.tf"]),
    config = ".tflint.hcl",
    plugins = [
        "@tflint_plugin_registry//:tf2_bin",
    ],
)

