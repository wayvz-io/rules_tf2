load("//tf2:def.bzl", "tf_module", "tf_test")

# Define the module
tf_module(
    name = "simple_module",
    srcs = glob(["*.tf"]) + ["README.md"],
    providers = [
        "@tf_provider_registry//:random_3",
        "@tf_provider_registry//:local_2",
        "@tf_provider_registry//:null_3",
