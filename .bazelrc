# Bazel configuration for rules_tf2

build --enable_workspace=false

# Enable isolated extension usages for conditional nixpkgs setup
build --experimental_isolated_extension_usages

# Use local disk cache
build --disk_cache=~/.cache/bazel-disk-cache

# Show test errors
test --test_output=errors

# Build with optimization
build -c opt

# Ensure we use the platform's host configuration
build --host_platform=@platforms//host

# Enable runfiles
build --enable_runfiles

# Show progress
build --show_progress
build --show_progress_rate_limit=5

# Test configuration
test --test_verbose_timeout_warnings

# Alias for testing the main codebase without vendored modules
# Usage: bazel test :all-tests
# This is defined in the root BUILD file

# Java: use the downloaded remote JDK (rules_java) so no host or Nix JDK is
# required. --config=nix overrides these to the Nix-provided runtime below.
build --java_language_version=21
build --tool_java_language_version=21
build --java_runtime_version=remotejdk_21
build --tool_java_runtime_version=remotejdk_21

# Set C++ standard to C++23 (required by modern dependencies like Abseil)
build --cxxopt=-std=c++23
build --host_cxxopt=-std=c++23

# Build Go in pure mode (no cgo). The ruleset's Go code and its dependencies are
# pure Go, and pure mode avoids the hermetic LLVM toolchain's force-included
# redacted_dates.h header, which clang cannot resolve when rules_go invokes it
# from the cgo stdlib builder.
build --@rules_go//go/config:pure=true

# ----------------------------------------------------------------------------
# Optional Nix toolchains — opt in with `--config=nix`.
#
# By default rules_tf2 builds with stock/hermetic toolchains (LLVM CC, remote
# JDK, downloaded Go + mdbook) and needs no Nix. `--config=nix` swaps in the
# Nix-provided CC + Java toolchains from the flake dev-shell. The Nix repos are
# referenced ONLY here (via --extra_toolchains), so they are fetched only when
# this config is active; a default build never needs Nix installed.
# ----------------------------------------------------------------------------
build:nix --host_platform=@rules_nixpkgs_core//platforms:host
build:nix --extra_toolchains=@nixpkgs_config_cc_toolchains//:all,@nixpkgs_java_runtime_toolchain//:all,@nixpkgs_java_jdk_toolchain//:all
build:nix --java_runtime_version=nixpkgs_java
build:nix --tool_java_runtime_version=nixpkgs_java

# Remote Build Execution (RBE) Configuration
#
# With the DEFAULT (stock/hermetic) toolchains, actions resolve to downloaded
# toolchain repos (LLVM CC, remote JDK, Go) that Bazel ships to the workers like
# any other external repository — a vanilla Ubuntu RBE worker needs no special
# preparation.
#
# With `--config=nix`, action toolchains resolve to /nix/store paths instead, so
# each worker must have the matching /nix/store closure synced (a vanilla worker
# lacks /nix/store and will fail). The local Buildbarn smoke test demonstrates
# this by bind-mounting the host store into the worker (see //tools/rbe-local).
# Point --config=rbe at your own executor.
#
# For a local Buildbarn smoke test (podman), see //tools/rbe-local and use
# `--config=rbe_local` (endpoint grpc://localhost:8980).
startup --host_jvm_args=-Djava.net.preferIPv4Stack=true
build:rbe --remote_executor=grpc://localhost:8980  # replace with your RBE endpoint
build:rbe --remote_instance_name=default
build:rbe --extra_execution_platforms=//tools/remote-toolchains:rbe_nix_platform
build:rbe --jobs=64
build:rbe --remote_timeout=3600
build:rbe --incompatible_strict_action_env
build:rbe --remote_download_toplevel
build:rbe --action_env=PATH
build:rbe --verbose_failures

# Local Buildbarn smoke test (see //tools/rbe-local). Standalone (does NOT inherit
# --config=rbe) so it can target a local podman-hosted Buildbarn cleanly. The stock
# hardlinking worker registers under the instance name "hardlinking".
build:rbe_local --remote_executor=grpc://localhost:8980
build:rbe_local --remote_instance_name=hardlinking
build:rbe_local --extra_execution_platforms=//tools/remote-toolchains:rbe_local_platform
build:rbe_local --incompatible_strict_action_env
build:rbe_local --remote_download_toplevel
build:rbe_local --verbose_failures
