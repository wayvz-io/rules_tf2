# Bazel configuration for rules_tf2

build --enable_workspace=false

# Enable isolated extension usages for conditional nixpkgs setup
build --experimental_isolated_extension_usages

# Use local disk cache
build --disk_cache=~/.cache/bazel-disk-cache

# Show test errors
test --test_output=errors

# Build with optimization
build -c opt

# Ensure we use the platform's host configuration
build --host_platform=@platforms//host

# Enable runfiles
build --enable_runfiles

# Show progress
build --show_progress
build --show_progress_rate_limit=5

# Test configuration
test --test_verbose_timeout_warnings

# Alias for testing the main codebase without vendored modules
# Usage: bazel test :all-tests
# This is defined in the root BUILD file

build --host_platform=@rules_nixpkgs_core//platforms:host
build --java_runtime_version=nixpkgs_java
build --tool_java_runtime_version=nixpkgs_java
build --java_language_version=21
build --tool_java_language_version=21
build --extra_toolchains=@nixpkgs_java_runtime_toolchain//:all # necessary on NixOS only

# Set C++ standard to C++23 (required by modern dependencies like Abseil)
build --cxxopt=-std=c++23
build --host_cxxopt=-std=c++23

# Remote Build Execution (RBE) Configuration
# Forcing IPV4 due to lack of internal ipv6
startup --host_jvm_args=-Djava.net.preferIPv4Stack=true
build:rbe --remote_executor=grpc://bb.lab.wayvz.io:8980
build:rbe --remote_instance_name=default
build:rbe --extra_execution_platforms=//tools/remote-toolchains:rbe_nix_platform
build:rbe --jobs=64
build:rbe --remote_timeout=3600
build:rbe --incompatible_strict_action_env
build:rbe --remote_download_toplevel
build:rbe --action_env=PATH
build:rbe --verbose_failures
build:rbe --toolchain_resolution_debug=.*
