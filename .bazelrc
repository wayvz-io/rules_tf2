# Bazel configuration for rules_tf2

build --enable_workspace=false

# Enable isolated extension usages for conditional nixpkgs setup
build --experimental_isolated_extension_usages

# Local disk cache at setup-bazel's default path, so local and CI agree.
build --disk_cache=~/.cache/bazel-disk

# Show test errors
test --test_output=errors

# Build with optimization
build -c opt

# Ensure we use the platform's host configuration
build --host_platform=@platforms//host

# Enable runfiles
build --enable_runfiles

# Show progress
build --show_progress
build --show_progress_rate_limit=5

# Test configuration
test --test_verbose_timeout_warnings

# Alias for testing the main codebase without vendored modules
# Usage: bazel test :all-tests
# This is defined in the root BUILD file

# Java: use the downloaded remote JDK (rules_java) so no host or Nix JDK is
# required. --config=nix overrides these to the Nix-provided runtime below.
build --java_language_version=21
build --tool_java_language_version=21
build --java_runtime_version=remotejdk_21
build --tool_java_runtime_version=remotejdk_21

# Set C++ standard to C++23 (required by modern dependencies like Abseil)
build --cxxopt=-std=c++23
build --host_cxxopt=-std=c++23

# Build Go in pure mode (no cgo); avoids the LLVM toolchain's redacted_dates.h
# force-include, which clang can't resolve from the cgo stdlib builder.
build --@rules_go//go/config:pure=true

# Download the protoc bundled in protobuf 33.4 instead of compiling it from
# source, which otherwise costs stardoc (//docs) a ~35 min build on a cold RBE
# worker. Starlark flag: keep it off `common` (would break `mod`/`version`);
# `test` inherits it from `build`.
build --@protobuf//bazel/toolchains:prefer_prebuilt_protoc

# ----------------------------------------------------------------------------
# Remote Build Execution (RBE)
#
# Stock toolchains are downloaded and shipped to workers as external repos, so a
# vanilla Ubuntu worker needs no special prep. --config=rbe targets a remote
# executor; --config=rbe_local targets the local podman Buildbarn (//tools/rbe-local).
# The shell/PATH pins make actions use the worker's tools, not the host's (a Nix
# dev-shell would otherwise leak /nix/store paths into remote actions).
# ----------------------------------------------------------------------------
startup --host_jvm_args=-Djava.net.preferIPv4Stack=true

build:rbe --remote_executor=grpc://localhost:8980  # replace with your RBE endpoint
build:rbe --remote_instance_name=default
build:rbe --extra_execution_platforms=//tools/remote-toolchains:rbe_platform
build:rbe --shell_executable=/bin/bash
build:rbe --action_env=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
build:rbe --host_action_env=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
build:rbe --jobs=64
build:rbe --remote_timeout=3600
build:rbe --incompatible_strict_action_env
build:rbe --remote_download_toplevel
build:rbe --verbose_failures

# Local podman Buildbarn (//tools/rbe-local); standalone, does not inherit :rbe.
build:rbe_local --remote_executor=grpc://localhost:8980
build:rbe_local --remote_instance_name=hardlinking
build:rbe_local --extra_execution_platforms=//tools/remote-toolchains:rbe_local_platform
build:rbe_local --shell_executable=/bin/bash
build:rbe_local --action_env=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
build:rbe_local --host_action_env=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
build:rbe_local --incompatible_strict_action_env
build:rbe_local --remote_download_toplevel
build:rbe_local --verbose_failures

# Shared/remote Buildbarn cluster reached over the network (e.g. the lab cluster
# over Tailscale). The worker image is the same catthehacker/act runner as the
# local podman worker, so this is the same stock-toolchain flow — only the
# endpoint, instance name and exec queue differ.
#
# Connection details (endpoint + instance name) are environment-specific and are
# intentionally NOT committed: put them in .bazelrc.user (gitignored), which is
# try-import'd at the end of this file. See .bazelrc.user.example for the template.
# The exec_properties on remote_platform must match the queue the cluster's
# scheduler advertises, or actions queue forever with no matching worker.
build:remote --extra_execution_platforms=//tools/remote-toolchains:remote_platform
build:remote --shell_executable=/bin/bash
build:remote --action_env=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
build:remote --host_action_env=PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
build:remote --incompatible_strict_action_env
build:remote --remote_timeout=3600
build:remote --jobs=4
build:remote --verbose_failures

# Build without the Bytes: keep action outputs in the cluster's CAS instead of
# downloading them to the client. Only outputs a local action actually needs are
# fetched, which is the big win over a remote link. Retry if the CAS evicts a
# blob a later action needs.
build:remote --remote_download_minimal
build:remote --experimental_remote_cache_eviction_retries=5

# Environment-specific overrides (RBE endpoint, instance name, local tweaks).
# Gitignored; optional — the build works without it. Loaded last so it wins.
try-import %workspace%/.bazelrc.user
